---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { contactFields } from "../lib/site";
---

<MainLayout
  title="Contact | RJ Tutoring"
  description="Reach out to RJ Tutoring to discuss SAT, ACT, or high school math tutoring needs."
>
  <section class="section-shell pt-12 md:pt-18">
    <SectionHeading
      eyebrow="Contact"
      title="Start with a tutoring inquiry"
      description="Share a few details about the student, the subject area, and the goals. That will make it easier to discuss fit, scheduling, and the best place to begin."
    />
  </section>

  <section class="section-shell mt-12">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="surface-card p-8 md:p-10">
        <h2 class="text-3xl text-[color:var(--ink)]">What to include</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          A strong first message makes it easier to understand goals and suggest the right next step.
        </p>
        <ul class="mt-6 grid gap-3 text-sm leading-7 text-[color:var(--muted)]">
          {
            contactFields.map((field) => (
              <li class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
                {field}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="surface-card p-8 md:p-10">
        <h2 class="text-3xl text-[color:var(--ink)]">Inquiry options</h2>
        <div class="mt-6 space-y-6">
          <div class="rounded-[1.5rem] border border-[color:var(--line)] bg-white/70 p-6">
            <h3 class="text-2xl text-[color:var(--ink)]">Google Form placeholder</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
              Replace this section with an embedded Google Form for incoming tutoring inquiries.
            </p>
            <!-- TODO: Replace this placeholder with your real Google Form embed code. -->
            <div class="mt-5 rounded-[1.25rem] border border-dashed border-[color:var(--line)] bg-[color:var(--surface-soft)] px-5 py-10 text-center text-sm font-semibold text-[color:var(--muted)]">
              Google Form embed goes here
            </div>
          </div>

          <div class="rounded-[1.5rem] border border-[color:var(--line)] bg-white/70 p-6">
            <h3 class="text-2xl text-[color:var(--ink)]">Email placeholder</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
              Families who prefer email can use the placeholder button below until the real business email is added.
            </p>
            <!-- TODO: Replace your-email@example.com with your real tutoring email address. -->
            <div class="mt-5">
              <a
                class="button-primary"
                href="mailto:your-email@example.com?subject=RJ%20Tutoring%20Inquiry"
              >
                Email RJ Tutoring
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
