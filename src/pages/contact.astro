---
import MainLayout from "../layouts/MainLayout.astro";
import { contactFields } from "../lib/site";
---

<MainLayout
  title="Contact | Rohit Jagga"
  description="Reach out to Rohit Jagga to ask about SAT, ACT, or high school math tutoring."
>
  <section class="section-shell pt-12 md:pt-18">
    <div class="max-w-3xl">
      <div class="eyebrow">Contact</div>
      <h1 class="mt-4 text-5xl leading-tight text-[color:var(--ink)] md:text-6xl">Get in touch</h1>
      <p class="mt-5 text-base leading-8 text-[color:var(--muted)] md:text-lg">
        If you're reaching out about tutoring, a short note with the details below is enough to get
        started.
      </p>
    </div>
  </section>

  <section class="section-shell mt-12">
    <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="surface-card p-8 md:p-10">
        <h2 class="text-3xl text-[color:var(--ink)]">What to include</h2>
        <ul class="mt-6 grid gap-3 text-sm leading-7 text-[color:var(--muted)]">
          {
            contactFields.map((field) => (
              <li class="subject-chip">
                {field}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="surface-card p-8 md:p-10">
        <h2 class="text-3xl text-[color:var(--ink)]">Inquiry options</h2>
        <div class="mt-6 space-y-6">
          <div class="soft-panel p-6">
            <h3 class="text-2xl text-[color:var(--ink)]">Google Form</h3>
            <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
              You can fill out the inquiry form directly here.
            </p>
            <div class="mt-5 overflow-hidden rounded-[1.25rem] border border-[color:var(--line)] bg-white">
              <iframe
                src="https://docs.google.com/forms/d/e/1FAIpQLScBLlZHxmByTCucKhGIq3syBlKxs0TR_8-9uvDtg7NclMadvg/viewform?embedded=true"
                width="100%"
                height="1645"
                style="border:0;"
                title="RJ Tutoring Inquiry Form"
              >
                Loading…
              </iframe>
            </div>
          </div>

          <div class="soft-panel p-6">
            <h3 class="text-2xl text-[color:var(--ink)]">Email</h3>
            <div class="mt-5">
              <a
                class="button-primary"
                href="mailto:rohitjagga02@gmail.com?subject=RJ%20Tutoring%20Inquiry"
              >
                Email me
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
