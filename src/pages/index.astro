---
import MainLayout from "../layouts/MainLayout.astro";
import { assetPath, basePath, subjectList } from "../lib/site";
---

<MainLayout
  title="Rohit Jagga | Tutoring"
  description="SAT, ACT, and high school math tutoring with Rohit Jagga."
>
  <section class="section-shell pt-12 md:pt-18">
    <div class="grid items-center gap-12 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="fade-rise">
        <div class="eyebrow">About</div>
        <h1 class="mt-6 max-w-4xl text-5xl leading-[1.02] text-[color:var(--ink)] md:text-7xl">
          Hi, I'm Rohit.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">
          I tutor SAT, ACT, and high school math, with a focus on making things clear, calm, and
          straightforward.
        </p>
        <p class="mt-4 max-w-2xl text-base leading-8 text-[color:var(--muted)] md:text-lg">
          I graduated from Penn in 2024, and I've spent the last several years tutoring,
          teaching, and working with students across test prep and math courses.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a class="button-primary" href={basePath("/contact")}>Contact</a>
          <span class="text-sm font-medium tracking-[0.08em] text-[color:var(--muted)] uppercase">
            Penn '24 · 5+ years of tutoring experience
          </span>
        </div>
      </div>

      <div class="fade-rise flex justify-center lg:justify-end">
        <div class="portrait-shell">
          <img
            src={assetPath("/images/rohit-jagga-headshot.jpg")}
            alt="Rohit Jagga outdoors with a scenic overlook in the background"
            class="portrait-image"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">About Me</div>
        <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">
          A little more about me
        </h2>
        <div class="mt-6 space-y-5 text-base leading-8 text-[color:var(--muted)]">
          <p>
            I graduated from the University of Pennsylvania with majors in Computer Science and
            Economics, and I enjoy helping students get more comfortable with subjects that can
            otherwise feel frustrating or rushed.
          </p>
          <p>
            My tutoring style is pretty direct: understand the concept, practice the right kinds of
            problems, and build confidence from there.
          </p>
          <p>
            I've also taught through Art of Problem Solving, which gave me a lot of experience
            working with different learning styles and goals.
          </p>
        </div>
      </div>

      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">Subjects</div>
        <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">What I tutor</h2>
        <p class="mt-5 max-w-xl text-base leading-8 text-[color:var(--muted)]">
          Most of my tutoring is in test prep and high school math, with some science support as
          well.
        </p>
        <ul class="mt-6 grid gap-3 text-sm leading-7 text-[color:var(--muted)]">
          {
            subjectList.map((subject) => (
              <li class="subject-chip">
                {subject}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card overflow-hidden p-8 md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <div class="eyebrow">Contact</div>
          <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">
            If you'd like to ask about tutoring, reach out here.
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-[color:var(--muted)] md:text-lg">
            The contact page has a short list of what to include and space for a form or email
            option.
          </p>
        </div>
        <a class="button-primary" href={basePath("/contact")}>Go to Contact</a>
      </div>
    </div>
  </section>
</MainLayout>
