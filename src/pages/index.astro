---
import MainLayout from "../layouts/MainLayout.astro";
import { assetPath, basePath, subjectList } from "../lib/site";
---

<MainLayout
  title="Rohit Jagga | Tutoring"
  description="SAT, ACT, and high school math tutoring with Rohit Jagga."
>
  <section class="section-shell pt-12 md:pt-18">
    <div class="grid items-center gap-12 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="fade-rise">
        <div class="eyebrow">About</div>
        <h1 class="mt-6 max-w-4xl text-5xl leading-[1.02] text-[color:var(--ink)] md:text-7xl">
          Hi, I'm Rohit.
        </h1>
        <p class="mt-3 max-w-2xl text-sm font-medium tracking-[0.08em] text-[color:var(--warm)] uppercase">
          Based in New York, NY and Charlotte, NC
        </p>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">
          Recent Penn '24 grad with majors in Computer Science and Economics. During high school, I
          scored a 1600 on the SAT and participated in several math contests like AMC & AIME. I
          mainly offer tutoring for SAT/ACT/standardized test prep, as well as various high school
          math & science classes.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a class="button-primary" href={basePath("/contact")}>Request Tutoring</a>
          <span class="text-sm font-medium tracking-[0.08em] text-[color:var(--muted)] uppercase">
            5+ years of tutoring exp across AoPS, NCVPS, etc.
          </span>
        </div>
      </div>

      <div class="fade-rise flex justify-center lg:justify-end">
        <div class="portrait-shell">
          <img
            src={assetPath("/images/rohit-jagga-headshot.jpg")}
            alt="Rohit Jagga outdoors with a scenic overlook in the background"
            class="portrait-image"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">About Me</div>
        <div class="mt-6 space-y-7 text-base leading-8 text-[color:var(--muted)]">
          <p>
            I graduated from the University of Pennsylvania with majors in Computer Science and
            Economics, and I enjoy helping students get more comfortable with subjects & concepts
            that they may be struggling with.
          </p>
          <p>
            Since 2020, I've been tutoring, teaching, and working with students across different
            platforms such as Art of Problem Solving (focused on contest math) and NCVPS (NC online
            coursework). My tutoring approach involves: understanding the fundamental concepts
            involved, practicing the right kinds of problems efficiently, and building confidence
            from there.
          </p>
        </div>
      </div>

      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">Subjects</div>
        <ul class="mt-4 grid gap-3 text-sm leading-7 text-[color:var(--muted)]">
          {
            subjectList.map((subject) => (
              <li class="subject-chip">
                {subject}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card overflow-hidden p-8 md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <div class="eyebrow">Contact</div>
          <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">
            To inquire about tutoring, please reach out here.
          </h2>
        </div>
        <a class="button-primary" href={basePath("/contact")}>Request Tutoring</a>
      </div>
    </div>
  </section>
</MainLayout>
