---
import FaqList from "../components/FaqList.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SubjectCard from "../components/SubjectCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { approachPillars, credentialHighlights, faqItems, subjectGroups } from "../lib/site";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
const previewSubjects = subjectGroups.flatMap((group) => group.subjects).slice(0, 6);
---

<MainLayout
  title="RJ Tutoring | SAT, ACT, and Math Tutoring"
  description="Parent-friendly SAT, ACT, and high school math tutoring from a 1600 SAT scorer and University of Pennsylvania graduate."
>
  <section class="section-shell pt-12 md:pt-18">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="fade-rise">
        <div class="eyebrow">Personalized tutoring for ambitious students</div>
        <h1 class="mt-6 max-w-4xl text-5xl leading-[1.02] text-[color:var(--ink)] md:text-7xl">
          SAT/ACT &amp; Math Tutoring from a 1600 SAT Scorer and UPenn Graduate
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">
          RJ Tutoring helps students strengthen fundamentals, sharpen test strategy, and grow more
          confident one thoughtful session at a time.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a class="button-primary" href={withBase("/contact")}>Request Tutoring</a>
          <a class="button-secondary" href={withBase("/services")}>View Subjects</a>
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          {
            credentialHighlights.map((item) => (
              <span class="pill">{item}</span>
            ))
          }
        </div>
      </div>

      <div class="fade-rise surface-card relative overflow-hidden p-5 md:p-7">
        <div class="absolute right-5 top-5 rounded-full bg-[color:var(--accent-soft)] px-4 py-2 text-xs font-extrabold uppercase tracking-[0.18em] text-[color:var(--accent)]">
          Parent-friendly. Modern. Trustworthy.
        </div>
        <div class="overflow-hidden rounded-[1.75rem] bg-[color:var(--surface-soft)]">
          <img
            src={withBase("/images/rohit-jagga-headshot.svg")}
            alt="Rohit Jagga outdoors with a scenic overlook in the background"
            class="aspect-[4/5] w-full object-cover object-center"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card p-8 md:p-10">
      <SectionHeading
        eyebrow="Tutoring approach"
        title="Built for understanding, not just short-term memorization"
        description="Sessions are designed to help students learn the reasoning behind the work, practice with intention, and show up more prepared for class, homework, and test day."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {
          approachPillars.map((pillar) => (
            <article class="rounded-[1.5rem] border border-[color:var(--line)] bg-white/70 p-6">
              <h3 class="text-2xl text-[color:var(--ink)]">{pillar.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{pillar.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <SectionHeading
      eyebrow="Subjects"
      title="Support across test prep and high school coursework"
      description="Whether the goal is a stronger SAT score, steadier class performance, or better mathematical confidence, tutoring can be tailored to the student's current level and timeline."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        previewSubjects.map((subject) => (
          <SubjectCard {...subject} />
        ))
      }
    </div>
    <div class="mt-8 flex justify-start">
      <a class="button-secondary" href={withBase("/services")}>See the full subject list</a>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Frequently asked"
        title="A few common questions from families"
        description="If you are deciding whether the fit is right, these answers are a good place to start."
      />
      <FaqList items={faqItems.slice(0, 4)} />
    </div>
    <div class="mt-8">
      <a class="button-secondary" href={withBase("/faq")}>View all FAQs</a>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card overflow-hidden p-8 md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <div class="eyebrow">Next step</div>
          <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">
            Ready to talk through goals, schedule, and the right starting point?
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-[color:var(--muted)] md:text-lg">
            Share a little about the student, the subject area, and what success would look like.
            From there, we can figure out the best plan for moving forward.
          </p>
        </div>
        <a class="button-primary" href={withBase("/contact")}>Request Tutoring</a>
      </div>
    </div>
  </section>
</MainLayout>
