---
import MainLayout from "../layouts/MainLayout.astro";
import { assetPath, basePath, credentialHighlights, subjectList } from "../lib/site";
---

<MainLayout
  title="RJ Tutoring | SAT, ACT, and Math Tutoring"
  description="SAT, ACT, and high school math tutoring from Rohit Jagga, a UPenn graduate and 1600 SAT scorer."
>
  <section class="section-shell pt-12 md:pt-18">
    <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="fade-rise">
        <div class="eyebrow">RJ Tutoring</div>
        <h1 class="mt-6 max-w-4xl text-5xl leading-[1.02] text-[color:var(--ink)] md:text-7xl">
          SAT/ACT and Math Tutoring with Rohit Jagga
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:var(--muted)] md:text-xl">
          UPenn graduate. 1600 SAT scorer. More than 5 years of tutoring and teaching experience.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a class="button-primary" href={basePath("/contact")}>Request Tutoring</a>
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          {
            credentialHighlights.map((item) => (
              <span class="pill">{item}</span>
            ))
          }
        </div>
      </div>

      <div class="fade-rise surface-card relative overflow-hidden p-5 md:p-7">
        <div class="overflow-hidden rounded-[1.75rem] bg-[color:var(--surface-soft)]">
          <img
            src={assetPath("/images/rohit-jagga-headshot.jpg")}
            alt="Rohit Jagga outdoors with a scenic overlook in the background"
            class="aspect-[4/5] w-full object-cover object-center"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">About Me</div>
        <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">A little background</h2>
        <div class="mt-6 space-y-5 text-base leading-8 text-[color:var(--muted)]">
          <p>
            I graduated from the University of Pennsylvania in 2024 with majors in Computer Science and Economics.
          </p>
          <p>
            In high school, I scored 1600 on the SAT and took courses including AP Calculus BC, AP Biology, AP Physics C, AP Chemistry, and AP Lang.
          </p>
          <p>
            I have 5+ years of tutoring and teaching experience, including work with Art of Problem Solving.
          </p>
        </div>
      </div>

      <div class="surface-card p-8 md:p-10">
        <div class="eyebrow">Subjects</div>
        <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">What I tutor</h2>
        <ul class="mt-6 grid gap-3 text-sm leading-7 text-[color:var(--muted)]">
          {
            subjectList.map((subject) => (
              <li class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
                {subject}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card overflow-hidden p-8 md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <div class="eyebrow">Contact</div>
          <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">
            Interested in tutoring?
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-[color:var(--muted)] md:text-lg">
            Go to the contact page to send an inquiry and share the student's grade, subject, goals, and scheduling preferences.
          </p>
        </div>
        <a class="button-primary" href={basePath("/contact")}>Request Tutoring</a>
      </div>
    </div>
  </section>
</MainLayout>
