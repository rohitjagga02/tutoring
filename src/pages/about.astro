---
import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<MainLayout
  title="About | RJ Tutoring"
  description="Learn more about Rohit Jagga's background, teaching style, and approach to SAT, ACT, and high school math tutoring."
>
  <section class="section-shell pt-12 md:pt-18">
    <SectionHeading
      eyebrow="About Rohit"
      title="A strong academic background with a teaching style that stays practical and approachable"
      description="Rohit Jagga combines high-level subject knowledge with a calm, student-centered tutoring approach that helps families feel supported and informed."
    />
  </section>

  <section class="section-shell mt-12">
    <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="surface-card overflow-hidden p-5">
        <img
          src={withBase("/images/rohit-jagga-headshot.svg")}
          alt="Rohit Jagga portrait"
          class="aspect-[4/5] w-full rounded-[1.5rem] object-cover object-center"
        />
      </div>

      <div class="surface-card p-8 md:p-10">
        <div class="space-y-6 text-base leading-8 text-[color:var(--muted)]">
          <p>
            Rohit graduated from the <span class="font-bold text-[color:var(--ink)]">University of Pennsylvania in 2024</span>
            with Honors in <span class="font-bold text-[color:var(--ink)]">Computer Science and Economics</span>.
            During high school, he earned a <span class="font-bold text-[color:var(--ink)]">1600 on the SAT</span>
            and completed advanced coursework across math, science, and English, including AP Calculus BC and AP Biology.
          </p>

          <p>
            He brings more than five years of teaching and tutoring experience across multiple settings. Since 2020,
            he has worked as a teaching assistant and grader with <span class="font-bold text-[color:var(--ink)]">Art of Problem Solving</span>,
            and he has supported students in coursework ranging from foundational algebra through calculus, along with selected science and standardized test preparation.
          </p>

          <p>
            What stands out most is not just the subject knowledge, but the way sessions are taught. The focus is on helping students understand why a method works,
            build dependable problem-solving habits, and become more confident tackling unfamiliar questions on their own.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="grid gap-5 md:grid-cols-3">
      <article class="surface-card p-7">
        <div class="eyebrow">Why tutor</div>
        <h2 class="mt-4 text-3xl text-[color:var(--ink)]">Make difficult subjects feel manageable</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Strong tutoring should lower anxiety, clarify the next step, and make students feel more capable after each session.
        </p>
      </article>

      <article class="surface-card p-7">
        <div class="eyebrow">Teaching philosophy</div>
        <h2 class="mt-4 text-3xl text-[color:var(--ink)]">Clarity, patience, and accountability</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Explanations stay structured and calm, expectations stay clear, and practice is tailored to the student's actual needs instead of a one-size-fits-all plan.
        </p>
      </article>

      <article class="surface-card p-7">
        <div class="eyebrow">Working style</div>
        <h2 class="mt-4 text-3xl text-[color:var(--ink)]">Built for both students and parents</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Sessions stay student-centered, while communication remains polished, transparent, and parent-friendly from the first inquiry onward.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell mt-20">
    <div class="surface-card p-8 md:p-10">
      <SectionHeading
        eyebrow="What families can expect"
        title="A thoughtful tutoring relationship, not just homework help"
        description="The goal is to meet students where they are, identify the most useful next steps, and help them build durable progress over time."
      />
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        <div class="rounded-[1.5rem] border border-[color:var(--line)] bg-white/70 p-6">
          <h3 class="text-2xl text-[color:var(--ink)]">During sessions</h3>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
            Students can expect clear explanations, active problem solving, and honest feedback about where they are improving and where they still need repetition.
          </p>
        </div>
        <div class="rounded-[1.5rem] border border-[color:var(--line)] bg-white/70 p-6">
          <h3 class="text-2xl text-[color:var(--ink)]">Over the long run</h3>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
            Families can expect a steady focus on stronger fundamentals, better study habits, and more confidence in schoolwork and testing situations.
          </p>
        </div>
      </div>

      <div class="mt-8">
        <a class="button-primary" href={withBase("/contact")}>Start the conversation</a>
      </div>
    </div>
  </section>
</MainLayout>
