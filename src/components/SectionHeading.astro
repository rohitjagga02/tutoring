---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { eyebrow, title, description, centered = false } = Astro.props;
---

<div class:list={["max-w-3xl", centered && "mx-auto text-center"]}>
  {eyebrow && <div class:list={["eyebrow", centered && "justify-center"]}>{eyebrow}</div>}
  <h2 class="mt-4 text-4xl leading-tight text-[color:var(--ink)] md:text-5xl">{title}</h2>
  {description && <p class="mt-5 text-base leading-8 text-[color:var(--muted)] md:text-lg">{description}</p>}
</div>
