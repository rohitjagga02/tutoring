---
interface Props {
  title: string;
  audience: string;
  focus: string;
  support: string;
}

const { title, audience, focus, support } = Astro.props;
---

<article class="surface-card h-full p-7">
  <h3 class="text-2xl text-[color:var(--ink)]">{title}</h3>
  <div class="mt-6 space-y-4 text-sm leading-7 text-[color:var(--muted)]">
    <p><span class="font-extrabold text-[color:var(--ink)]">Who it is for:</span> {audience}</p>
    <p><span class="font-extrabold text-[color:var(--ink)]">What we work on:</span> {focus}</p>
    <p><span class="font-extrabold text-[color:var(--ink)]">How tutoring helps:</span> {support}</p>
  </div>
</article>
