---
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<footer class="border-t border-[color:var(--line)] bg-[rgba(255,255,255,0.5)]">
  <div class="section-shell flex flex-col gap-6 py-10 md:flex-row md:items-end md:justify-between">
    <div class="max-w-xl">
      <div class="text-sm font-extrabold uppercase tracking-[0.18em] text-[color:var(--accent)]">RJ Tutoring</div>
      <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
        Personalized SAT, ACT, and high school math tutoring built around clear explanations,
        targeted practice, and long-term confidence.
      </p>
    </div>
    <div class="flex flex-wrap gap-4 text-sm font-semibold text-[color:var(--muted)]">
      <a href={withBase("/services")} class="hover:text-[color:var(--ink)]">Subjects</a>
      <a href={withBase("/about")} class="hover:text-[color:var(--ink)]">About</a>
      <a href={withBase("/faq")} class="hover:text-[color:var(--ink)]">FAQ</a>
      <a href={withBase("/contact")} class="hover:text-[color:var(--ink)]">Contact</a>
    </div>
  </div>
</footer>
